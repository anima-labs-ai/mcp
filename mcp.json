{
  "$schema": "https://raw.githubusercontent.com/modelcontextprotocol/registry/main/schema.json",
  "name": "@anima-labs/mcp",
  "displayName": "Anima — AI Agent Identity Platform",
  "description": "Give your AI agents real-world capabilities: email, voice, phone, virtual cards, credential vault, addresses, spend-requests, machine payments, and more. 197 tools for autonomous agent operations.",
  "version": "0.1.0",
  "author": {
    "name": "Anima Labs",
    "url": "https://animalabs.ai"
  },
  "license": "MIT",
  "repository": "https://github.com/anima-labs-ai/mcp",
  "homepage": "https://useanima.sh",
  "documentation": "https://docs.useanima.sh/mcp",
  "install": {
    "npm": "@anima-labs/mcp"
  },
  "runtime": "node",
  "transports": ["stdio", "http"],
  "authentication": {
    "type": "api_key",
    "env": "ANIMA_API_KEY",
    "description": "Get your API key at https://console.useanima.sh"
  },
  "categories": ["communication", "payments", "identity", "productivity"],
  "tags": [
    "ai-agent", "email", "voice", "virtual-cards", "vault", "phone", "sms",
    "identity", "spend-requests", "machine-payments", "x402", "browser-checkout",
    "agent-to-agent"
  ],
  "tools": {
    "count": 197,
    "groups": [
      "a2a", "address", "agent", "browser-payments", "cards", "domain",
      "email", "extension", "funding", "identity", "invoice", "message",
      "mpp", "organization", "phone", "pod", "registry", "security",
      "spend-requests", "utility", "vault", "voice", "wallet", "webhook", "x402"
    ]
  }
}
